# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Accounting SaaS"
DEBUG=true
ENVIRONMENT=development

# ── Security ─────────────────────────────────────────────────────────────────
# สร้างด้วย: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-random-32-byte-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────────────────────
# Development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/shared.sqlite
DB_ECHO=false

# Production (PostgreSQL) — ปลด comment บรรทัดนี้แทน
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/accounting

# ── Data directory ────────────────────────────────────────────────────────────
DATA_DIR=data

# ── Anthropic / OCR ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OCR_MODEL=claude-sonnet-4-6
OCR_MAX_TOKENS=4096
OCR_MAX_IMAGE_SIZE_MB=5.0

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=app-password
EMAIL_FROM=noreply@yourfirm.com

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]
