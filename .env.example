# ── AccCloud Environment Configuration ────────────────────────────────────────
# คัดลอกไปเป็น .env แล้วแก้ไขค่าให้ถูกต้องก่อน deploy
# ห้าม commit ไฟล์ .env ขึ้น version control เด็ดขาด

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Accounting SaaS"
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ── Security ──────────────────────────────────────────────────────────────────
# สร้างด้วย: openssl rand -hex 32
SECRET_KEY=change-me-to-random-32-byte-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
# ถ้าไม่ตั้ง DATABASE_URL ระบบจะ build URL จาก DATA_DIR อัตโนมัติ
# DATABASE_URL=sqlite+aiosqlite:////app/data/shared.sqlite
DB_ECHO=false

# ── Data directory ─────────────────────────────────────────────────────────────
# Railway: ตั้ง Volume mount ที่ /app/data ใน Dashboard
DATA_DIR=/app/data

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost","http://localhost:80"]

# ── Anthropic / OCR ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
OCR_MODEL=claude-sonnet-4-6
OCR_MAX_TOKENS=4096
OCR_MAX_IMAGE_SIZE_MB=5.0

# ── Upload ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30

# ── Email (optional — ใช้สำหรับ deadline notifications) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=app-password
EMAIL_FROM=noreply@yourfirm.com
